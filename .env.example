# Expert Homepage SaaS - Environment Variables
# Copy this file to .env.local and fill in the values

# Anthropic Claude API Key (AI 콘텐츠 생성용, 선택)
ANTHROPIC_API_KEY=

# 멀티테넌트 루트 도메인 (기본값: prosite.kr, 로컬 개발 시 생략 가능)
NEXT_PUBLIC_ROOT_DOMAIN=prosite.kr

# 네이버 검색 API (키워드 리서치용, 선택)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
